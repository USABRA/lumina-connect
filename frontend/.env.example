# Lumina Connect — frontend (copy to .env.local for dev)
# On Vercel: Project → Settings → Environment Variables (Production + Preview)

NEXT_PUBLIC_API_URL=http://localhost:8000

# Firebase Web app config (Console → Project settings → Your apps → Web)
# All four are required together for Firebase Auth in the browser.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
