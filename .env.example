# Lumina Connect - Environment Variables
# Copy to backend/.env and frontend/.env.local as needed

# --- Backend ---
DATABASE_URL=postgresql://lumina:lumina@localhost:5432/lumina_connect
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
LANDING_BASE_URL=http://localhost:3000/p

# Firebase Auth (Phase 3+)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Lead notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
LEAD_NOTIFY_EMAILS=

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
