# Database
DATABASE_URL=postgresql://lumina:lumina@localhost:5432/lumina_connect

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
LANDING_BASE_URL=http://localhost:3000/p

# Firebase Auth — set all three together (disables /auth/register and /auth/login).
# Service account JSON: Project settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# From JSON field "private_key" — keep \n between lines inside quotes in .env:
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# Local JWT auth (used when Firebase is not configured)
JWT_SECRET_KEY=dev-secret-change-in-production-use-32-chars-min

# Lead notifications (optional — requires SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# Comma-separated override; if empty, notifies all company users
LEAD_NOTIFY_EMAILS=

# Platform owner — comma-separated emails with /platform oversight access
PLATFORM_ADMIN_EMAILS=
