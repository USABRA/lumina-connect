# Database
DATABASE_URL=postgresql://lumina:lumina@localhost:5432/lumina_connect

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
LANDING_BASE_URL=http://localhost:3000/p

# Firebase Auth (Phase 3)
# Create a Firebase project → Project settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste private key with \n for newlines, or use a single line in quotes
FIREBASE_PRIVATE_KEY=

# Lead notifications (optional — requires SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# Comma-separated override; if empty, notifies all company users
LEAD_NOTIFY_EMAILS=
